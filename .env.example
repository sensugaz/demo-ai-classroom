# ============================================================================
# AI Classroom - Environment Variables
# ----------------------------------------------------------------------------
# Copy this file to ".env" and fill in the values before running:
#     cp .env.example .env
#
# These variables are consumed by docker-compose.yml and injected into the
# ai-service container. The backend and frontend services use static config
# defined directly in docker-compose.yml and do not require values here.
# ============================================================================

# --- Deployment / domain (nginx reverse proxy) ------------------------------
# Domain nginx should answer on. Leave unset for "_" (catch-all: serves on any
# domain or IP pointed at this host). Set to lock to one host.
# DOMAIN=classroom.example.com
# Public origin the browser loads from — used for backend CORS. Defaults to
# http://localhost. Set to your scheme + domain in production.
# PUBLIC_ORIGIN=https://classroom.example.com

# --- Cartesia (Text-to-Speech, en-US) ---------------------------------------
# API key from your Cartesia account dashboard.
CARTESIA_API_KEY=
# Voice ID used to synthesize the English audio output.
CARTESIA_VOICE_ID=
# Sonic model id (defaults to sonic-3.5, the latest Sonic model).
# CARTESIA_MODEL=sonic-3.5

# --- LLM via OpenRouter (Translation / Summary / Vocabulary / Flashcards) ---
# OpenRouter API key from https://openrouter.ai/keys
LLM_API_KEY=
# OpenRouter model id, e.g. openai/gpt-4o-mini, anthropic/claude-3.5-sonnet,
# google/gemini-2.0-flash-001. See https://openrouter.ai/models
LLM_MODEL=openai/gpt-4o-mini
# OpenRouter base URL (OpenAI-compatible). Defaults to OpenRouter if left blank.
# Override only to point at a different gateway (e.g. https://api.openai.com/v1).
LLM_BASE_URL=https://openrouter.ai/api/v1

# ============================================================================
# Google Cloud Speech-to-Text (Thai STT)
# ----------------------------------------------------------------------------
# Google STT does NOT use an env var key here. Instead you must place a
# service account JSON file at:
#
#     ./credentials/google-service-account.json
#
# The docker-compose file mounts ./credentials read-only into the ai-service
# container at /app/credentials, and sets
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-service-account.json
# See ./credentials/README.md for details.
# ============================================================================
