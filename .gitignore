# ----------------------------------------------------------------------------
# Environment / secrets
# ----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# Local provider credentials are never commit-eligible.
credentials/*.json

# TLS certs / keys (keep the folder + docs, ignore the secrets)
nginx/certs/*.pem
nginx/certs/*.key
nginx/certs/*.crt

# ----------------------------------------------------------------------------
# Node / Next.js (frontend)
# ----------------------------------------------------------------------------
node_modules/
.next/
out/
next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----------------------------------------------------------------------------
# Python (ai-service)
# ----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
.venv*/
venv/
.pytest_cache/
.mypy_cache/

# ----------------------------------------------------------------------------
# Go (backend)
# ----------------------------------------------------------------------------
bin/
*.exe
*.test
*.out
*.o
*.a

# ----------------------------------------------------------------------------
# Temp / runtime audio + scratch
# ----------------------------------------------------------------------------
/tmp/
tmp/

# ----------------------------------------------------------------------------
# OMC / tooling state
# ----------------------------------------------------------------------------
.omc/

# ----------------------------------------------------------------------------
# OS / editor
# ----------------------------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
